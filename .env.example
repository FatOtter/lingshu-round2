# =============================================================================
# LingShu Production Environment Variables
# Copy this file to .env and replace all placeholder values with real secrets.
# NEVER commit the .env file to version control.
# =============================================================================

# ── Host Ports ───────────────────────────────────────────────────────────────
FRONTEND_PORT=3100
BACKEND_PORT=8100

# ── Frontend ─────────────────────────────────────────────────────────────────
# The URL that the browser uses to reach the backend API.
# In production behind a reverse proxy, this is typically the public domain.
NEXT_PUBLIC_API_URL=http://localhost:8100

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=lingshu
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password
POSTGRES_DB=lingshu

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_strong_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_strong_password

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must include the public frontend URL.
LINGSHU_CORS_ORIGINS=https://your-domain.example.com

# ── Authentication ───────────────────────────────────────────────────────────
# CRITICAL: Generate a strong random secret (e.g., openssl rand -hex 32)
LINGSHU_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
LINGSHU_JWT_ALGORITHM=HS256
LINGSHU_ACCESS_TOKEN_TTL=900
LINGSHU_REFRESH_TOKEN_TTL=604800

# ── Seed Admin Account ──────────────────────────────────────────────────────
# Created on first startup. Change the password immediately after first login.
LINGSHU_SEED_ADMIN_EMAIL=admin@your-domain.example.com
LINGSHU_SEED_ADMIN_PASSWORD=CHANGE_ME_admin_strong_password
LINGSHU_SEED_TENANT_NAME=Default

# ── RBAC ─────────────────────────────────────────────────────────────────────
# Set to true to enable Casbin RBAC permission checks
LINGSHU_RBAC_ENABLED=false

# ── OIDC / SSO (optional) ───────────────────────────────────────────────────
# Leave empty to disable SSO
LINGSHU_OIDC_ISSUER_URL=
LINGSHU_OIDC_CLIENT_ID=
LINGSHU_OIDC_CLIENT_SECRET=
LINGSHU_OIDC_REDIRECT_URI=

# ── Copilot LLM (optional) ──────────────────────────────────────────────────
# Provider: gemini / openai / anthropic
LINGSHU_COPILOT_PROVIDER=gemini
LINGSHU_COPILOT_API_KEY=
LINGSHU_COPILOT_MODEL=
